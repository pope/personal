# EditorConfig is awesome: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true

[*.{json,toml,yml,gyp}]
indent_size = 2
indent_style = space

[*.go]
indent_style = tab

[*.rs]
indent_size = 4
indent_style = space

[Makefile]
indent_style = tab
